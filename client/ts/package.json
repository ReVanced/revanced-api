{
    "name": "@revanced/api-client",
    "version": "0.0.1",
    "module": "./dist/index.js",
    "publishConfig": {
        "registry": "https://npm.pkg.github.com"
    },
    "devDependencies": {
        "typescript": "^6.0.2"
